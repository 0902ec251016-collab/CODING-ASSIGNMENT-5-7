#include <iostream>
#include <string>
using namespace std;

struct Element {
    string name;
    int atomicNumber;
    double atomicMass;
    int group;
    int period;
    string electronicConfig;
    string oxidationState;
    string application;
};

Element getElementInfo(string symbol) {
    if (symbol == "Na") {
        return {"Sodium", 11, 22.99, 1, 3, "[Ne] 3s1", "+1", "Used in street lighting (sodium vapor lamps)"};
    } else if (symbol == "Fe") {
        return {"Iron", 26, 55.85, 8, 4, "[Ar] 3d6 4s2", "+2, +3", "Construction material (steel production)"};
    } else if (symbol == "Cl") {
        return {"Chlorine", 17, 35.45, 17, 3, "[Ne] 3s2 3p5", "-1, +1, +5, +7", "Water purification (disinfectant)"};
    } else if (symbol == "Cu") {
        return {"Copper", 29, 63.55, 11, 4, "[Ar] 3d10 4s1", "+1, +2", "Electrical wiring (excellent conductor)"};
    } else {
        return {"Unknown", 0, 0.0, 0, 0, "-", "-", "No data available"};
    }
}

int main() {
    string symbol;
    cout << "Enter element symbol (e.g., Na, Fe, Cl, Cu): ";
    cin >> symbol;

    Element e = getElementInfo(symbol);

    if (e.atomicNumber != 0) {
        cout << "\nElement: " << e.name;
        cout << "\nAtomic Number: " << e.atomicNumber;
        cout << "\nAtomic Mass: " << e.atomicMass;
        cout << "\nGroup: " << e.group;
        cout << "\nPeriod: " << e.period;
        cout << "\nElectronic Configuration: " << e.electronicConfig;
        cout << "\nCommon Oxidation State: " << e.oxidationState;
        cout << "\nEngineering Application: " << e.application << endl;
    } else {
        cout << "Element data not available." << endl;
    }

    return 0;
}
